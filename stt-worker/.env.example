# STT worker 設定（複製成 .env 或直接 export）

# 監看的錄音資料夾（WSL 路徑；Windows D:\record 對應 /mnt/d/record）
STT_WATCH_DIR=/mnt/d/record

# 逐字稿輸出資料夾（openclaw 的輸入）
STT_OUTBOX_DIR=~/stt-outbox

# 可選：處理後把來源音檔搬到這裡封存（需與 WATCH_DIR 同磁碟才會 rename 成功）
# STT_DONE_DIR=~/record-done

# whisper 容器位址
WHISPER_URL=http://localhost:9000
# 若容器有設 WHISPER_API_KEY，這裡填一樣的值
# WHISPER_API_KEY=

# 轉譯參數
STT_LANGUAGE=zh                 # 留空則自動偵測
STT_RESPONSE_FORMAT=text        # text | json | verbose_json | srt | vtt
STT_MODEL=whisper-1             # OpenAI 相容欄位，多數 server 會忽略

# 行為調校
STT_POLL_INTERVAL=5             # 輪詢秒數
STT_STABLE_SECONDS=2            # 檔案大小穩定多久才視為寫完
STT_REQUEST_TIMEOUT=600         # 單檔轉譯逾時（長錄音要夠大）
STT_MAX_RETRIES=3
STT_LOG_LEVEL=INFO

# 單例互斥用的 localhost port（同時只允許一支 worker）
STT_LOCK_PORT=47654
# 若設定，log 導向此檔（app 以 detached 方式啟動時會用，因無主控台）
# STT_LOG_FILE=worker.log
