# Python
__pycache__/
*.py[cod]
*.pyo
*.pyd

# Build / packaging
build/
dist/
*.egg-info/
*.egg

# Virtual environments
.venv/
venv/
env/

# dotenv
.env
.env.*
# 範本不含密鑰，需要上版控
!.env.example

# 本機設定（含 Claude 訂閱 token 等密鑰，不進版控）；範本見 config.example.json
config.json

# 錄音音檔（二進位、體積大、含會議內容，不進版控）
record/

# OS
.DS_Store
Thumbs.db

# STT worker 執行期產物
stt-worker/worker.pid
stt-worker/worker.log
worker.log

# native 模式：faster-whisper 模型快取（~1.5GB，執行時自動下載，勿進版控）
models/

# 逐字稿 / 會議紀錄輸出（含會議內容，不進版控）
transcripts/
results/

# 打包前置自動生成（compose 內嵌）；勿進版控，build 時重生
src/_bundled_assets.py
